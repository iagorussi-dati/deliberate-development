{
  "name": "dd-prd",
  "description": "Escreve PRD a partir do contexto da conversa e publica como GitHub Issue.",
  "model": "claude-opus-4.6",
  "prompt": "file://./prompts/agent-prd.md",
  "tools": [
    "read",
    "grep",
    "glob",
    "code",
    "shell"
  ],
  "allowedTools": [
    "read",
    "grep",
    "glob",
    "code"
  ],
  "toolsSettings": {
    "shell": {
      "allowedCommands": [
        "gh .*",
        "git log.*",
        "git diff.*",
        "git status"
      ],
      "autoAllowReadonly": true
    }
  },
  "resources": [
    "skill://.kiro/skills/git/SKILL.md",
    "file://.kiro/skills/to-prd/SKILL.md"
  ],
  "mcpServers": {
    "git": {
      "command": "uvx",
      "args": [
        "mcp-server-git"
      ]
    }
  },
  "keyboardShortcut": "ctrl+3",
  "welcomeMessage": "agent-prd — deliberate development flow"
}
