{
  "name": "agent-issues",
  "description": "Quebra PRD em vertical slices e publica como GitHub Issues.",
  "model": "claude-opus-4.6",
  "prompt": "file://./prompts/agent-issues.md",
  "tools": [
    "read",
    "grep",
    "glob",
    "code",
    "shell"
  ],
  "allowedTools": [
    "read",
    "grep",
    "glob",
    "code"
  ],
  "toolsSettings": {
    "shell": {
      "allowedCommands": [
        "gh .*",
        "git log.*",
        "git diff.*",
        "git status"
      ],
      "autoAllowReadonly": true
    }
  },
  "resources": [
    "skill://./skills/git/SKILL.md"
  ],
  "mcpServers": {
    "git": {
      "command": "uvx",
      "args": [
        "mcp-server-git"
      ]
    }
  },
  "keyboardShortcut": "ctrl+4",
  "welcomeMessage": "agent-issues — deliberate development flow"
}
